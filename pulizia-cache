# ==============================================================================
# PARSING ARGOMENTI
# ==============================================================================

APP_LIST=(thunderbird firefox librewolf chrome chromium pcloud konqueror)

show_help() {
    echo ""
    echo "  Uso: pulizia-cache [--dry-run] [--list] [app1 app2 ...]"
    echo ""
    echo "  Senza argomenti app: pulizia completa di tutte le applicazioni."
    echo ""
    echo "  App disponibili: ${APP_LIST[*]}"
    echo ""
    echo "  Opzioni:"
    echo "    --dry-run   Mostra cosa verrebbe cancellato senza farlo davvero"
    echo "    --list      Mostra le app disponibili ed esce"
    echo ""
}

APPS_TO_CLEAN=()

for arg in "$@"; do
    case "$arg" in
        --dry-run) DRY_RUN=true ;;
        --list)
            echo "App disponibili: ${APP_LIST[*]}"
            exit 0
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        *)
            # Verifica che sia un'app valida
            valid=false
            for a in "${APP_LIST[@]}"; do
                [ "$arg" = "$a" ] && valid=true && break
            done
            if $valid; then
                APPS_TO_CLEAN+=("$arg")
            else
                echo -e "${RED}Argomento sconosciuto: $arg${RESET}"
                show_help
                exit 1
            fi
            ;;
    esac
done

# Se nessuna app specificata, pulisci tutto
if [ ${#APPS_TO_CLEAN[@]} -eq 0 ]; then
    APPS_TO_CLEAN=("${APP_LIST[@]}")
fi

# ==============================================================================
# MAIN
# ==============================================================================

clear

echo ""
echo -e "${BOLD}🔄 PULIZIA CACHE SISTEMA${RESET}"
echo "========================================"
if $DRY_RUN; then
    echo -e "${YELLOW}  ⚠️  MODALITÀ DRY-RUN — nessun file verrà cancellato${RESET}"
fi
echo "  App: ${APPS_TO_CLEAN[*]}"
echo "========================================"

for app in "${APPS_TO_CLEAN[@]}"; do
    case "$app" in
        thunderbird) clean_thunderbird ;;
        firefox)     clean_firefox ;;
        librewolf)   clean_librewolf ;;
        chrome)      clean_chrome ;;
        chromium)    clean_chromium ;;
        pcloud)      clean_pcloud ;;
        konqueror)   clean_konqueror ;;
    esac
done

echo ""
echo "========================================"
if $DRY_RUN; then
    echo -e "${YELLOW}  📊 Spazio che verrebbe liberato: $(format_bytes "$BYTES_TOTAL")${RESET}"
    echo -e "${YELLOW}  ℹ️  DRY-RUN completato. Nessun file è stato eliminato.${RESET}"
else
    echo -e "${GREEN}  📊 Spazio liberato: $(format_bytes "$BYTES_TOTAL")${RESET}"
    echo -e "${GREEN}  🎉 PULIZIA COMPLETATA CON SUCCESSO!${RESET}"
fi
echo "========================================"
echo ""
